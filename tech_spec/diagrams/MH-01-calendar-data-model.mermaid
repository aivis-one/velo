erDiagram
    PRACTICE {
        uuid id PK
        uuid master_id FK
        string title
        text description
        jsonb tags
        timestamp start_time
        timestamp end_time
        int duration_minutes
        int capacity
        int booked_count
        decimal price
        string currency
        enum visibility
        enum status
        jsonb recurrence_rule
        string zoom_meeting_id
        string zoom_join_url
        string zoom_host_url
        timestamp created_at
        timestamp updated_at
    }
    
    PRACTICE_TAG {
        uuid id PK
        string name
        string category
        int usage_count
    }
    
    MASTER ||--o{ PRACTICE : creates
    PRACTICE }o--o{ PRACTICE_TAG : has
