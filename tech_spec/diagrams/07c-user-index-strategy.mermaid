graph TB
    subgraph "Table: users"
        TABLE[users table<br/>1M rows]
    end
    
    subgraph "Indexes"
        PK[PRIMARY KEY: id<br/>B-tree]
        
        GIN[GIN Index<br/>credentials<br/>General JSONB queries]
        
        TG_IDX[Partial Index<br/>credentials->'telegram'->>'id'<br/>Fast Telegram lookups]
        
        WEB_IDX[Partial Index<br/>credentials->'web'->>'email'<br/>Fast web email lookups]
        
        DC_IDX[Partial Index<br/>credentials->'discord'->>'id'<br/>Fast Discord lookups]
    end
    
    TABLE --> PK
    TABLE --> GIN
    TABLE --> TG_IDX
    TABLE --> WEB_IDX
    TABLE --> DC_IDX
    
    TG_IDX -.-> |"Only where<br/>telegram exists"| TG_PARTIAL[Covers ~80% users]
    WEB_IDX -.-> |"Only where<br/>web exists"| WEB_PARTIAL[Covers ~20% users]
    DC_IDX -.-> |"Only where<br/>discord exists"| DC_PARTIAL[Covers ~5% users]
    
    classDef tableStyle fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    classDef indexStyle fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    classDef partialStyle fill:#e8f5e9,stroke:#388e3c,stroke-width:1px
    
    class TABLE tableStyle
    class PK,GIN,TG_IDX,WEB_IDX,DC_IDX indexStyle
    class TG_PARTIAL,WEB_PARTIAL,DC_PARTIAL partialStyle

%% Performance:
%% - Telegram ID lookup: ~12ms (with partial index)
%% - Web email lookup: ~15ms (with partial index)
%% - General JSONB query: ~80ms (with GIN index)
%% - Without indexes: ~450ms (sequential scan)
