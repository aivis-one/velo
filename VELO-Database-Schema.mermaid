erDiagram
    %% ═══════════════════════════════════════════════════════════════
    %% VELO Platform — Database Schema (актуальная версия)
    %% Дата: 6 февраля 2026
    %% ═══════════════════════════════════════════════════════════════

    %% ───────────────────────────────────────────────────────────────
    %% CORE: Users & Masters
    %% ───────────────────────────────────────────────────────────────
    
    USER {
        uuid id PK
        enum role "user|master|admin"
        jsonb credentials "telegram, google, apple"
        string first_name
        string last_name
        string avatar_url
        string timezone "default: UTC"
        string language "default: en"
        boolean is_active "default: true"
        decimal balance_user "computed by listener"
        timestamp created_at
        timestamp updated_at
        timestamp last_login_at
    }

    MASTER_PROFILE {
        uuid user_id PK,FK
        jsonb data "account, availability, profile, settings, stats"
        decimal frozen_amount "computed by listener"
        decimal available_amount "computed by listener"
        timestamp created_at
        timestamp updated_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% PRACTICES
    %% ───────────────────────────────────────────────────────────────

    PRACTICE {
        uuid id PK
        uuid master_id FK
        enum type "live|series|one_on_one|replay"
        enum status "draft|scheduled|live|completed|cancelled"
        string title
        text description
        timestamp scheduled_at
        int duration_minutes
        string timezone
        int max_participants
        int current_participants "default: 0"
        string zoom_link
        uuid parent_practice_id FK "for series"
        timestamp created_at
        timestamp updated_at
    }

    PRACTICE_PRICING {
        uuid practice_id PK,FK
        boolean is_free "default: true"
        int price_cents
        string currency "default: USD"
        timestamp created_at
        timestamp updated_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% BOOKINGS & WAITLIST
    %% ───────────────────────────────────────────────────────────────

    BOOKING {
        uuid id PK
        uuid practice_id FK
        uuid user_id FK
        uuid purchase_id FK "NOT NULL - always exists"
        enum status "pending|confirmed|attended|no_show|cancelled"
        timestamp booked_at
        timestamp cancelled_at
        string cancellation_reason
        timestamp joined_at
        timestamp left_at
        timestamp created_at
        timestamp updated_at
    }

    WAITLIST {
        uuid id PK
        uuid practice_id FK
        uuid user_id FK
        int position
        enum status "waiting|notified|converted|expired"
        timestamp joined_at
        timestamp notified_at
        timestamp expires_at
        timestamp created_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% PAYMENTS: Double-Entry Ledgers
    %% ───────────────────────────────────────────────────────────────

    USER_LEDGER {
        uuid id PK
        uuid user_id FK
        decimal amount "positive or negative"
        enum status "pending|done|cancelled"
        string reason "payment:123, purchase:practice=456"
        text notes
        timestamp created_at
    }

    MASTER_LEDGER {
        uuid id PK
        uuid user_id FK
        uuid practice_id FK "nullable, for frozen tracking"
        decimal amount
        boolean is_frozen "true until practice completed"
        enum status "pending|done|cancelled"
        string reason "sale:practice=456, commission:practice=456"
        text notes
        timestamp created_at
    }

    COMPANY_LEDGER {
        uuid id PK
        decimal amount
        enum type "commission|marketing|refund|withdrawal_fee"
        enum status "pending|done|cancelled"
        string reason
        timestamp created_at
    }

    PAYMENT {
        uuid id PK
        uuid user_id FK
        enum direction "in|out"
        int amount_cents
        string currency
        enum status "pending|confirmed|failed|refunded"
        string stripe_session_id
        string stripe_payment_intent_id
        jsonb metadata
        timestamp created_at
        timestamp confirmed_at
    }

    PURCHASE {
        uuid id PK
        uuid user_id FK
        uuid practice_id FK
        uuid promo_id FK "nullable"
        int amount_cents "full price"
        int discount_cents "promo discount"
        int paid_cents "actual paid by user"
        enum status "pending|completed|cancelled|refunded"
        timestamp created_at
        timestamp completed_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% PROMOS
    %% ───────────────────────────────────────────────────────────────

    PROMO {
        uuid id PK
        string code UK
        enum type "company|master"
        uuid master_id FK "nullable, for master promos"
        uuid practice_id FK "nullable, limit to one practice"
        int discount_percent "5, 25, 50, 75, 100"
        int max_uses "nullable = unlimited"
        int used_count "default: 0"
        timestamp valid_from
        timestamp valid_until
        boolean first_purchase_only "default: false"
        boolean is_active "default: true"
        timestamp created_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% DIARY / STATE
    %% ───────────────────────────────────────────────────────────────

    CHECKIN {
        uuid id PK
        uuid practice_id FK
        uuid user_id FK
        uuid booking_id FK
        enum mood "low|mid|high"
        text comment
        timestamp created_at
    }

    FEEDBACK {
        uuid id PK
        uuid practice_id FK
        uuid user_id FK
        uuid booking_id FK
        enum rating "fire|good|confused"
        text comment
        timestamp created_at
    }

    DIARY_ENTRY {
        uuid id PK
        uuid user_id FK
        uuid practice_id FK "nullable"
        string title
        text content
        enum mood "nullable"
        timestamp created_at
        timestamp updated_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% NOTIFICATIONS
    %% ───────────────────────────────────────────────────────────────

    NOTIFICATION {
        uuid id PK
        string source
        text text
        jsonb buttons
        enum target_type "user|all|filter"
        string target_value
        int priority "1-10, default: 5"
        enum status "pending|sent|failed"
        boolean is_silent
        boolean auto_delete
        timestamp send_at
        timestamp expires_at
        timestamp created_at
    }

    NOTIFICATION_DELIVERY {
        uuid id PK
        uuid notification_id FK
        uuid user_id FK
        enum status "pending|sent|failed"
        int attempts "default: 0"
        text error_message
        timestamp sent_at
        timestamp created_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% ADMIN / MODERATION
    %% ───────────────────────────────────────────────────────────────

    REPORT {
        uuid id PK
        uuid reporter_id FK
        enum target_type "user|master|practice"
        uuid target_id
        string reason
        enum status "pending|resolved|dismissed"
        uuid resolved_by FK "nullable"
        text resolution_note
        timestamp created_at
        timestamp resolved_at
    }

    %% ───────────────────────────────────────────────────────────────
    %% AUDIT LOG (immutable, 3-5 years retention)
    %% ───────────────────────────────────────────────────────────────

    AUDIT_LOG {
        uuid id PK
        timestamp created_at "indexed"
        string event "purchase_created, refund, role_changed"
        uuid actor_id FK "nullable - who performed action"
        enum actor_type "user|master|admin|system"
        string target_type "user|practice|booking|payment"
        uuid target_id
        jsonb data "full context snapshot"
        string ip_address "nullable"
        string user_agent "nullable"
        string trace_id "for distributed tracing"
    }

    %% ───────────────────────────────────────────────────────────────
    %% FUTURE (розетки)
    %% ───────────────────────────────────────────────────────────────

    SUBSCRIPTION {
        uuid id PK
        uuid user_id FK
        enum plan "monthly|yearly"
        enum status "active|cancelled|expired"
        string stripe_subscription_id
        timestamp current_period_start
        timestamp current_period_end
        timestamp created_at
    }

    %% ═══════════════════════════════════════════════════════════════
    %% RELATIONSHIPS
    %% ═══════════════════════════════════════════════════════════════

    %% Core
    USER ||--o| MASTER_PROFILE : "becomes master"
    
    %% Practices
    USER ||--o{ PRACTICE : "master creates"
    PRACTICE ||--|| PRACTICE_PRICING : "has pricing"
    PRACTICE ||--o| PRACTICE : "parent (series)"
    
    %% Bookings
    USER ||--o{ BOOKING : "books"
    PRACTICE ||--o{ BOOKING : "has bookings"
    PURCHASE ||--|| BOOKING : "creates booking"
    USER ||--o{ WAITLIST : "joins waitlist"
    PRACTICE ||--o{ WAITLIST : "has waitlist"
    
    %% Payments (Double-Entry)
    USER ||--o{ USER_LEDGER : "balance transactions"
    USER ||--o{ MASTER_LEDGER : "master earnings"
    PRACTICE ||--o{ MASTER_LEDGER : "frozen until completed"
    USER ||--o{ PAYMENT : "external payments"
    USER ||--o{ PURCHASE : "purchases"
    PRACTICE ||--o{ PURCHASE : "is purchased"
    PROMO ||--o{ PURCHASE : "applied to"
    
    %% Promos
    USER ||--o{ PROMO : "master creates"
    PRACTICE ||--o{ PROMO : "limited to"
    
    %% Diary/State
    USER ||--o{ CHECKIN : "submits"
    PRACTICE ||--o{ CHECKIN : "has checkins"
    BOOKING ||--|| CHECKIN : "linked to"
    USER ||--o{ FEEDBACK : "gives"
    PRACTICE ||--o{ FEEDBACK : "receives"
    BOOKING ||--|| FEEDBACK : "linked to"
    USER ||--o{ DIARY_ENTRY : "writes"
    PRACTICE ||--o{ DIARY_ENTRY : "linked to (optional)"
    
    %% Notifications
    NOTIFICATION ||--o{ NOTIFICATION_DELIVERY : "delivered to"
    USER ||--o{ NOTIFICATION_DELIVERY : "receives"
    
    %% Admin
    USER ||--o{ REPORT : "reports"
    USER ||--o{ REPORT : "resolves"
    
    %% Audit
    USER ||--o{ AUDIT_LOG : "actor"
    
    %% Future
    USER ||--o| SUBSCRIPTION : "subscribes"
