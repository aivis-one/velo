# =============================================================================
# VELO Backend — .dockerignore
# =============================================================================
# Same idea as .gitignore, but for Docker.
# When you run `docker build`, Docker sends ALL files in the directory
# to the Docker daemon (the "build context"). This file excludes
# unnecessary files — making builds faster and images smaller.
#
# NOTE: tests/ are NOT excluded — they are copied into the image when
# INSTALL_DEV=true (test VPS). The Dockerfile handles this conditionally.
# =============================================================================

.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.git/
.gitignore
.env
.env.example
docker-compose*.yml
Dockerfile
*.egg-info/
dist/
build/