# =============================================================================
# VELO Backend — Environment Variables
# =============================================================================
# On VPS: auto-generated by install_velo.sh with random passwords.
# Hosts are Docker service names (postgres, redis) — NOT localhost.
# =============================================================================

APP_ENV=development

# Database — host "postgres" = Docker service name
DATABASE_URL=postgresql+asyncpg://velo:change-me@postgres:5432/velo
POSTGRES_DB=velo
POSTGRES_USER=velo
POSTGRES_PASSWORD=change-me

# Redis — host "redis" = Docker service name
# REDIS_PASSWORD is also read by docker-compose to start Redis with --requirepass.
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me

# CORS
CORS_ORIGINS=*

# Security — generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# Telegram
TELEGRAM_BOT_TOKEN=
# Bot URL for notification deep links. Username resolved via Telegram getMe.
TELEGRAM_BOT_URL=
# Live Telegram link host. The backend rewrites every Telegram URL onto it --
# both the bot URL above and the avatar URLs Telegram sends in initData.
TELEGRAM_LINK_DOMAIN=

# Session TTL (days)
SESSION_TTL_DAYS=30

# Logging
LOG_LEVEL=DEBUG

# Stripe (Phase 6.3) — set STRIPE_SECRET_KEY=TEST + ALLOW_STRIPE_STUB=true to
# run with the stub path (fake payments, no money moves, no real key needed).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Written by install_velo.sh's generate_env, but not a field on Settings in
# config.py -- nothing in the backend currently reads it. Kept here because
# this file's job is to document what the installer actually writes, not
# just what the app consumes.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
ALLOW_STRIPE_STUB=false