# =============================================================================
# VELO Backend — Environment Variables Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env to git (it's in .gitignore)
# =============================================================================

# --- Application ---
APP_ENV=development

# --- Database (PostgreSQL) ---
# postgresql+asyncpg:// tells SQLAlchemy to use asyncpg driver
DATABASE_URL=postgresql+asyncpg://velo:velo@localhost:5432/velo

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
