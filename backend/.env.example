# =============================================================================
# VELO Backend — Environment Variables Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env to git (it's in .gitignore)
#
# NOTE ON PORTS:
#   Local dev uses port 5433 for PostgreSQL (5432 may be taken by Homebrew).
#   Production uses 5432 (no conflicts on dedicated VPS).
# =============================================================================

# --- Application ---
APP_ENV=development

# --- Database (PostgreSQL) ---
# Local dev: port 5433 (Docker container maps 5433->5432 inside)
# Production: port 5432 (standard)
DATABASE_URL=postgresql+asyncpg://velo:velo@localhost:5433/velo

# These are used by docker-compose.yml to create the database.
# Must match the user/pass/db in DATABASE_URL above.
POSTGRES_DB=velo
POSTGRES_USER=velo
POSTGRES_PASSWORD=velo

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER use the default value in production!
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
