flowchart TB
    START([User pays for practice<br/>$50])

    subgraph "STEP 1: Registration"
        REG[User registers for practice]
        CHECK{Has enough<br/>balance?}
        TOPUP[Top up balance<br/>via Stripe]

        TRANS1[Double-Entry Transaction]
        UL1[user_ledger: -50<br/>reason: purchase:practice=456]
        ML1[master_ledger: +50<br/>is_frozen = TRUE<br/>practice_id = 456]
        PUR1[purchase: pending<br/>paid_cents = 5000]
        BOOK1[booking: confirmed]

        RESULT1[Master Balance:<br/>frozen = $50<br/>available = $0]
    end

    subgraph "STEP 2: Practice Completed"
        COMPLETE[Practice status → completed]

        TRANS2[Unfreeze + Commission Transaction]
        ML2[master_ledger:<br/>UPDATE is_frozen = FALSE<br/>WHERE practice_id = 456]
        ML3[master_ledger: -7.50<br/>reason: commission:practice=456]
        CL1[company_ledger: +7.50<br/>type: commission]
        PUR2[purchase: completed]

        RESULT2[Master Balance:<br/>frozen = $0<br/>available = $42.50]
    end

    subgraph "STEP 3: Withdrawal"
        REQUEST[Master requests withdrawal<br/>$100]
        CHECK2{available_amount<br/>>= 100 + fee?}
        REJECT[Reject: insufficient funds]

        TRANS3[Withdrawal Transaction]
        ML4[master_ledger: -100<br/>reason: withdrawal:payment=789]
        CL2[company_ledger: +2<br/>type: withdrawal_fee]
        PAY1[payment: pending<br/>direction: out<br/>amount = $98]

        ADMIN[Admin confirms payout]
        PAY2[payment: confirmed]
        PAYOUT[Manual bank transfer $98]

        RESULT3[Master Balance:<br/>available -= $100]
    end

    %% Flow
    START --> REG
    REG --> CHECK
    CHECK -->|No| TOPUP
    TOPUP --> TRANS1
    CHECK -->|Yes| TRANS1

    TRANS1 --> UL1
    TRANS1 --> ML1
    TRANS1 --> PUR1
    TRANS1 --> BOOK1

    UL1 --> RESULT1
    ML1 --> RESULT1
    PUR1 --> RESULT1
    BOOK1 --> RESULT1

    RESULT1 -.->|Practice happens| COMPLETE

    COMPLETE --> TRANS2
    TRANS2 --> ML2
    TRANS2 --> ML3
    TRANS2 --> CL1
    TRANS2 --> PUR2

    ML2 --> RESULT2
    ML3 --> RESULT2
    CL1 --> RESULT2
    PUR2 --> RESULT2

    RESULT2 -.->|Later| REQUEST

    REQUEST --> CHECK2
    CHECK2 -->|No| REJECT
    CHECK2 -->|Yes| TRANS3

    TRANS3 --> ML4
    TRANS3 --> CL2
    TRANS3 --> PAY1

    PAY1 --> ADMIN
    ADMIN --> PAY2
    PAY2 --> PAYOUT

    ML4 --> RESULT3
    CL2 --> RESULT3

    %% Styling
    classDef frozen fill:#bbdefb,stroke:#1976d2,stroke-width:2px
    classDef available fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    classDef transaction fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    classDef decision fill:#ffe0b2,stroke:#e65100,stroke-width:2px

    class ML1,RESULT1 frozen
    class ML2,ML3,ML4,RESULT2,RESULT3 available
    class TRANS1,TRANS2,TRANS3 transaction
    class CHECK,CHECK2 decision

    %% Notes
    NOTE1[Frozen: Money waiting for practice<br/>Available: Money ready to withdraw<br/>Commission: 15% charged AFTER practice]

    style NOTE1 fill:#f3e5f5,stroke:#4a148c,stroke-width:2px
