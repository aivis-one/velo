graph TB
    subgraph "VELO Platform — Modular Monolith"

        subgraph "FastAPI Application"
            API[API Layer<br/>FastAPI Routers]

            subgraph "Modules"
                AUTH[auth<br/>Telegram WebApp Auth]
                USERS[users<br/>Profiles, Roles]
                MASTERS[masters<br/>Master Profiles]
                PRACTICES[practices<br/>CRUD Practices]
                BOOKINGS[bookings<br/>Bookings, Waitlist]
                PAYMENTS[payments<br/>Ledgers, Stripe]
                NOTIF[notifications<br/>Telegram Bot]
                DIARY[diary<br/>Check-ins, Feedbacks]
                ADMIN[admin<br/>Verification, Moderation]
            end

            CORE[Core Layer<br/>DB, Redis, Config, Middlewares]
        end

        subgraph "External Services"
            STRIPE[Stripe<br/>Payments]
            TELEGRAM[Telegram Bot API<br/>Notifications]
            WEBAPP[Telegram WebApp<br/>Frontend]
        end

        subgraph "Infrastructure"
            POSTGRES[(PostgreSQL 16<br/>Primary DB)]
            REDIS[(Redis 7<br/>Sessions, Cache)]
        end
    end

    %% Connections
    WEBAPP --> API
    API --> AUTH
    API --> USERS
    API --> MASTERS
    API --> PRACTICES
    API --> BOOKINGS
    API --> PAYMENTS
    API --> NOTIF
    API --> DIARY
    API --> ADMIN

    AUTH --> CORE
    USERS --> CORE
    MASTERS --> CORE
    PRACTICES --> CORE
    BOOKINGS --> CORE
    PAYMENTS --> CORE
    NOTIF --> CORE
    DIARY --> CORE
    ADMIN --> CORE

    CORE --> POSTGRES
    CORE --> REDIS

    PAYMENTS --> STRIPE
    NOTIF --> TELEGRAM

    %% Styling
    classDef module fill:#e1f5ff,stroke:#01579b,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef infra fill:#f3e5f5,stroke:#4a148c,stroke-width:2px

    class AUTH,USERS,MASTERS,PRACTICES,BOOKINGS,PAYMENTS,NOTIF,DIARY,ADMIN module
    class STRIPE,TELEGRAM,WEBAPP external
    class POSTGRES,REDIS infra

    %% Notes
    NOTE1[MVP: Один FastAPI сервис<br/>Будущее: Каждый модуль → микросервис]

    style NOTE1 fill:#fff9c4,stroke:#f57f17,stroke-width:2px
