.DS_Store
.idea/
desc/

# Secrets & Environment — safety net for root-level .env files.
# Subdirectories (backend/, frontend/) have their own .gitignore
# that also excludes .env, but this catches misplaced files.
.env
.env.*

# Local handoff / working docs (kickoff, prompts, seed context). NOT code —
# never committed. Lives next to the project as the single working location
# (consolidated out of GoogleDrive 2026-06-02). Local-only, not synced.
/.handoff/

# Local scratch. Two producers, both write here by design, neither belongs in git:
#   1. Standalone HTML previews — the operator confirms visual changes by opening
#      a preview, not by reading a description. Serve them via the `tmp-static`
#      entry in .claude/launch.json. A preview is spent once he has looked at it.
#   2. probekit report output — `.tmp/probekit-review` is the configured report_dir
#      for nine audit skills (ПРОМТ №435), so every run writes here.
# Untracked-but-not-ignored was the actual problem: every probekit run dirtied
# `git status`, which is how 8.7MB of one-shot previews eventually gets committed
# by accident.
/.tmp/