# =============================================================================
# VELO Frontend -- Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# Only variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# Backend API base URL (no trailing slash).
# In Docker/production: empty (Nginx proxies /api/* to backend).
# For local dev against remote: https://api.talentir.info
VITE_API_BASE_URL=
